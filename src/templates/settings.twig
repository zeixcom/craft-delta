{# Plugin settings page #}

{% import '_includes/forms.twig' as forms %}

{{ forms.textField({
    first: true,
    label: 'Diff Context Lines'|t('craft-delta'),
    instructions: 'Number of unchanged lines to show around changes.'|t('craft-delta'),
    id: 'diffContext',
    name: 'diffContext',
    value: settings.diffContext,
    type: 'number',
    min: 0,
    max: 20,
    size: 5,
    errors: settings.getErrors('diffContext'),
}) }}

{{ forms.textField({
    label: 'Max Field Length'|t('craft-delta'),
    instructions: 'Maximum characters before showing a simplified diff. Prevents performance issues on very large fields.'|t('craft-delta'),
    id: 'maxFieldLength',
    name: 'maxFieldLength',
    value: settings.maxFieldLength,
    type: 'number',
    min: 1000,
    size: 10,
    errors: settings.getErrors('maxFieldLength'),
}) }}

{{ forms.lightswitchField({
    label: 'Show Unchanged Fields'|t('craft-delta'),
    instructions: 'Show unchanged fields by default in the diff view.'|t('craft-delta'),
    id: 'defaultShowUnchanged',
    name: 'defaultShowUnchanged',
    on: settings.defaultShowUnchanged,
}) }}
